APP_NAME=MIOT
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Jakarta
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# MySQL / Database
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=Sistem_Camera_MIOT
DB_USERNAME=root
DB_PASSWORD=root

# Cache, Session, Queue
CACHE_STORE=file
CACHE_PREFIX=
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
QUEUE_CONNECTION=sync

# Reverb / Broadcasting
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=314585
REVERB_APP_KEY=j42ddfft9pcvefpkb2jl
REVERB_APP_SECRET=ckjtzrwtquh4uusmxvdm
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_ALLOWED_ORIGINS="http://localhost:8000,http://127.0.0.1:8000"

VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST=127.0.0.1
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http

# MinIO / S3 Storage
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin123
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=cctv
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true
AWS_URL=http://localhost:9000/cctv

# EMQX
MQTT_BROKER_HOST=emqx
MQTT_BROKER_PORT=1883
MQTT_BROKER_PROTOCOL=mqtt
EMQX_API_URL=http://emqx:18083/api/v5
EMQX_API_KEY=
EMQX_API_SECRET=
EMQX_CALLBACK_URL=http://web:80

# Detection Service
DETECTION_SERVICE_URL=http://detection-service:8000
MOTION_THRESHOLD=0.5

# FCM Configuration
FCM_PROJECT_ID=your-firebase-project-id
FIREBASE_CREDENTIALS_PATH=storage/app/firebase-service-account.json
FCM_COOLDOWN=30
